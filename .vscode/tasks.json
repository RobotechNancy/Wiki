{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🪄 Setup project",
      "command": "python ${workspaceFolder}/bin/setup.sh",
      "windows": {
        "command": "${workspaceFolder}/bin/setup.ps1"
      },
      "type": "shell",
      "group": "build",
      "detail": "Install all necessary tools",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "🌐 Start dev server",
      "command": "npm run dev",
      "type": "shell",
      "group": "build",
      "detail": "vitepress dev docs",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "🔨 Build project",
      "command": "pnpm run build",
      "type": "shell",
      "group": "build",
      "detail": "vitepress build docs",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "🌳 Generate tree",
      "command": "npm run gen",
      "type": "shell",
      "group": "build",
      "detail": "node generate-pages.mjs",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      }
    },
    {
      "label": "🖼️ Compress image",
      "command": "${workspaceFolder}/bin/convert_to_webp.sh -y",
      "type": "shell",
      "windows": {
        "command": "& 'C:\\Program Files\\Git\\bin\\bash.exe' ${workspaceFolder}\\bin\\convert_to_webp.sh -y",
      },
      "group": "build",
      "detail": "Convert images to Webp to reduce size",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      }
    },
  ]
}